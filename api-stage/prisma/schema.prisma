generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                     String                       @id @default(cuid())
  uuid                   String                       @unique @default(uuid())
  name                   String
  subdomain              String?                      @unique
  domain                 String?                      @unique
  status                 TenantStatus                 @default(TRIAL)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  auditLogs              AuditLog[]
  bankaHavaleler         BankaHavale[]
  basitSiparisler        BasitSiparis[]
  cariler                Cari[]
  cekSenetler            CekSenet[]
  invoices               Fatura[]
  invitations            Invitation[]
  invoiceProfits         InvoiceProfit[]
  kasalar                Kasa[]
  masraflar              Masraf[]
  personeller            Personel[]
  purchaseOrders         PurchaseOrder[]
  satınAlmaIrsaliyeleri SatınAlmaIrsaliyesi[]       @relation("SatınAlmaIrsaliyesiTenant")
  satinAlmaSiparisleri   SatınAlmaSiparisi[]
  satisIrsaliyeleri      SatisIrsaliyesi[]            @relation("SatisIrsaliyesiTenant")
  sayimlar               Sayim[]
  siparisler             Siparis[]
  stoklar                Stok[]
  subscription           Subscription?
  systemParameters       SystemParameter[]
  tahsilatlar            Tahsilat[]
  technicians            Technician[]
  teklifler              Teklif[]
  settings               TenantSettings?
  users                  User[]
  maintenanceReminders   VehicleMaintenanceReminder[]
  vehicles               Vehicle[]
  warehouseTransfers     WarehouseTransfer[]
  warehouses             Warehouse[]
  workOrders             WorkOrder[]
  randevular             Randevu[]
  bankalar               Banka[]
  bordrolar              Bordro[]
  satisElemanlari        SatisElemani[]
  maasPlanlari           MaasPlani[]
  maasOdemeler           MaasOdeme[]
  maasOdemeDetaylari     MaasOdemeDetay[]
  avanslar               Avans[]
  avansMahsuplasmalar    AvansMahsuplasma[]

  @@index([subdomain])
  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("tenants")
}

model TenantSettings {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  companyName  String?
  taxNumber    String?
  address      String?
  logoUrl      String?
  features     Json?
  limits       Json?
  timezone     String   @default("Europe/Istanbul")
  locale       String   @default("tr-TR")
  currency     String   @default("TRY")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  city         String?
  companyType  String?  @default("COMPANY")
  country      String?
  district     String?
  email        String?
  firstName    String?
  lastName     String?
  mersisNo     String?
  neighborhood String?
  phone        String?
  postalCode   String?
  taxOffice    String?
  tcNo         String?
  website      String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("TRY")
  billingPeriod BillingPeriod  @default(MONTHLY)
  trialDays     Int            @default(0)
  baseUserLimit Int            @default(1)
  features      Json?
  limits        Json?
  isActive      Boolean        @default(true)
  isPopular     Boolean        @default(false)
  isBasePlan    Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive])
  @@index([isBasePlan])
  @@map("plans")
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  planId                String
  status                SubscriptionStatus @default(TRIAL)
  startDate             DateTime           @default(now())
  endDate               DateTime
  trialEndsAt           DateTime?
  canceledAt            DateTime?
  nextBillingDate       DateTime?
  lastBillingDate       DateTime?
  autoRenew             Boolean            @default(true)
  iyzicoSubscriptionRef String?            @unique
  additionalUsers       Int                @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  moduleLicenses        ModuleLicense[]
  payments              Payment[]
  plan                  Plan               @relation(fields: [planId], references: [id])
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("TRY")
  status          PaymentStatus @default(PENDING)
  iyzicoPaymentId String?       @unique
  iyzicoToken     String?       @unique
  conversationId  String?       @unique
  invoiceNumber   String?
  invoiceUrl      String?
  paidAt          DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  paymentMethod   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([iyzicoPaymentId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("payments")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tenantId   String?
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id                             String                    @id @default(uuid())
  uuid                           String                    @unique @default(uuid())
  email                          String
  username                       String
  password                       String
  firstName                      String?
  lastName                       String?
  fullName                       String
  phone                          String?
  avatarUrl                      String?
  role                           UserRole                  @default(USER)
  status                         UserStatus                @default(ACTIVE)
  isActive                       Boolean                   @default(true)
  refreshToken                   String?
  tokenVersion                   Int                       @default(0)
  tenantId                       String?
  emailVerified                  Boolean                   @default(false)
  lastLoginAt                    DateTime?
  createdAt                      DateTime                  @default(now())
  updatedAt                      DateTime                  @updatedAt
  bankaHavaleLogs                BankaHavaleLog[]
  createdBankaHavaleler          BankaHavale[]             @relation("BankaHavaleCreatedBy")
  deletedBankaHavaleler          BankaHavale[]             @relation("BankaHavaleDeletedBy")
  updatedBankaHavaleler          BankaHavale[]             @relation("BankaHavaleUpdatedBy")
  cekSenetLogs                   CekSenetLog[]
  createdCekSenetler             CekSenet[]                @relation("CekSenetCreatedBy")
  deletedCekSenetler             CekSenet[]                @relation("CekSenetDeletedBy")
  updatedCekSenetler             CekSenet[]                @relation("CekSenetUpdatedBy")
  deletedBankaHavaleRecords      DeletedBankaHavale[]      @relation("DeletedBankaHavaleDeletedBy")
  deletedCekSenetRecords         DeletedCekSenet[]         @relation("DeletedCekSenetDeletedBy")
  faturaLogs                     FaturaLog[]
  createdFaturalar               Fatura[]                  @relation("FaturaCreatedBy")
  deletedFaturalar               Fatura[]                  @relation("FaturaDeletedBy")
  updatedFaturalar               Fatura[]                  @relation("FaturaUpdatedBy")
  createdKasaHareketler          KasaHareket[]             @relation("KasaHareketCreatedBy")
  createdKasalar                 Kasa[]                    @relation("KasaCreatedBy")
  updatedKasalar                 Kasa[]                    @relation("KasaUpdatedBy")
  createdPersonelOdemeler        PersonelOdeme[]           @relation("PersonelOdemeCreatedBy")
  createdPersoneller             Personel[]                @relation("PersonelCreatedBy")
  updatedPersoneller             Personel[]                @relation("PersonelUpdatedBy")
  createdPriceCards              PriceCard[]               @relation("PriceCardCreatedBy")
  updatedPriceCards              PriceCard[]               @relation("PriceCardUpdatedBy")
  createdSatınAlmaIrsaliyeleri  SatınAlmaIrsaliyesi[]    @relation("SatınAlmaIrsaliyesiCreatedBy")
  deletedSatınAlmaIrsaliyeleri  SatınAlmaIrsaliyesi[]    @relation("SatınAlmaIrsaliyesiDeletedBy")
  updatedSatınAlmaIrsaliyeleri  SatınAlmaIrsaliyesi[]    @relation("SatınAlmaIrsaliyesiUpdatedBy")
  satınAlmaIrsaliyesiLogs       SatınAlmaIrsaliyesiLog[] @relation("SatınAlmaIrsaliyesiLogUser")
  satinAlmaSiparisLogs           SatınAlmaSiparisLog[]    @relation("SatınAlmaSiparisLogUser")
  createdSatinAlmaSiparisler     SatınAlmaSiparisi[]      @relation("SatınAlmaSiparisiCreatedBy")
  deletedSatinAlmaSiparisler     SatınAlmaSiparisi[]      @relation("SatınAlmaSiparisiDeletedBy")
  updatedSatinAlmaSiparisler     SatınAlmaSiparisi[]      @relation("SatınAlmaSiparisiUpdatedBy")
  createdSatisIrsaliyeleri       SatisIrsaliyesi[]         @relation("SatisIrsaliyesiCreatedBy")
  deletedSatisIrsaliyeleri       SatisIrsaliyesi[]         @relation("SatisIrsaliyesiDeletedBy")
  updatedSatisIrsaliyeleri       SatisIrsaliyesi[]         @relation("SatisIrsaliyesiUpdatedBy")
  satisIrsaliyesiLogs            SatisIrsaliyesiLog[]      @relation("SatisIrsaliyesiLogUser")
  createdSayimlar                Sayim[]                   @relation("SayimCreatedBy")
  onayladigiSayimlar             Sayim[]                   @relation("SayimOnaylayan")
  updatedSayimlar                Sayim[]                   @relation("SayimUpdatedBy")
  sessions                       Session[]
  siparisHazirliklar             SiparisHazirlik[]         @relation("SiparisHazirlikCreatedBy")
  siparisLogs                    SiparisLog[]
  createdSiparisler              Siparis[]                 @relation("SiparisCreatedBy")
  deletedSiparisler              Siparis[]                 @relation("SiparisDeletedBy")
  updatedSiparisler              Siparis[]                 @relation("SiparisUpdatedBy")
  stockMoves                     StockMove[]               @relation("StockMoveCreatedBy")
  createdTahsilatlar             Tahsilat[]                @relation("TahsilatCreatedBy")
  deletedTahsilatlar             Tahsilat[]                @relation("TahsilatDeletedBy")
  teklifLogs                     TeklifLog[]               @relation("TeklifLogUser")
  createdTeklifler               Teklif[]                  @relation("TeklifCreatedBy")
  deletedTeklifler               Teklif[]                  @relation("TeklifDeletedBy")
  updatedTeklifler               Teklif[]                  @relation("TeklifUpdatedBy")
  licenses                       UserLicense[]
  tenant                         Tenant?                   @relation(fields: [tenantId], references: [id])
  warehouseTransferLogs          WarehouseTransferLog[]
  createdWarehouseTransfers      WarehouseTransfer[]       @relation("WarehouseTransferCreatedBy")
  deletedWarehouseTransfers      WarehouseTransfer[]       @relation("WarehouseTransferDeletedBy")
  createdBordrolar               Bordro[]                  @relation("BordroCreatedBy")
  hazirlananWarehouseTransfers   WarehouseTransfer[]       @relation("WarehouseTransferHazirlayan")
  onaylananWarehouseTransfers    WarehouseTransfer[]       @relation("WarehouseTransferOnaylayan")
  teslimAlinanWarehouseTransfers WarehouseTransfer[]       @relation("WarehouseTransferTeslimAlan")
  updatedWarehouseTransfers      WarehouseTransfer[]       @relation("WarehouseTransferUpdatedBy")
  approvedWorkOrderLines         WorkOrderLine[]           @relation("ApprovedByUser")
  inAppNotifications             InAppNotification[]
  createdAvanslar                Avans[]                   @relation("AvansCreatedBy")
  createdMaasOdemeler            MaasOdeme[]               @relation("MaasOdemeCreatedBy")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model Stok {
  id                           String                       @id @default(uuid())
  stokKodu                     String
  tenantId                     String?
  stokAdi                      String
  aciklama                     String?
  birim                        String
  alisFiyati                   Decimal                      @db.Decimal(10, 2)
  satisFiyati                  Decimal                      @db.Decimal(10, 2)
  kdvOrani                     Int                          @default(20)
  kritikStokMiktari            Int                          @default(0)
  kategori                     String?
  anaKategori                  String?
  altKategori                  String?
  marka                        String?
  model                        String?
  oem                          String?
  olcu                         String?
  raf                          String?
  barkod                       String?
  tedarikciKodu                String?
  esdegerGrupId                String?
  aracMarka                    String?
  aracModel                    String?
  aracMotorHacmi               String?
  aracYakitTipi                String?
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  basitSiparisler              BasitSiparis[]               @relation("BasitSiparisStok")
  faturaKalemleri              FaturaKalemi[]
  invoiceProfits               InvoiceProfit[]
  priceCards                   PriceCard[]
  productBarcodes              ProductBarcode[]
  productLocationStocks        ProductLocationStock[]
  purchaseOrderItems           PurchaseOrderItem[]          @relation("PurchaseOrderItemStok")
  satinAlmaIrsaliyesiKalemleri SatınAlmaIrsaliyesiKalemi[] @relation("SatınAlmaIrsaliyesiKalemiStok")
  satinAlmaSiparisKalemleri    SatınAlmaSiparisKalemi[]    @relation("SatınAlmaSiparisKalemiStok")
  satisIrsaliyesiKalemleri     SatisIrsaliyesiKalemi[]      @relation("SatisIrsaliyesiKalemiStok")
  sayimKalemleri               SayimKalemi[]
  siparisKalemleri             SiparisKalemi[]
  solutionPackageParts         SolutionPackagePart[]
  costHistory                  StockCostHistory[]
  stockMoves                   StockMove[]
  esdegers                     StokEsdeger[]                @relation("Stok1")
  esdegers2                    StokEsdeger[]                @relation("Stok2")
  stokHareketleri              StokHareket[]
  esdegerGrup                  EsdegerGrup?                 @relation(fields: [esdegerGrupId], references: [id])
  tenant                       Tenant?                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teklifKalemleri              TeklifKalemi[]
  urunRaflar                   UrunRaf[]
  warehouseCriticalStocks      WarehouseCriticalStock[]
  warehouseTransferItems       WarehouseTransferItem[]
  workOrderLines               WorkOrderLine[]

  @@unique([stokKodu, tenantId])
  @@unique([barkod, tenantId])
  @@index([tenantId])
  @@index([tenantId, stokKodu])
  @@index([tenantId, barkod])
  @@map("stoklar")
}

model PriceCard {
  id            String        @id @default(uuid())
  stokId        String        @map("stok_id")
  type          PriceCardType
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("TRY")
  effectiveFrom DateTime?     @map("effective_from")
  effectiveTo   DateTime?     @map("effective_to")
  note          String?
  createdBy     String?       @map("created_by")
  updatedBy     String?       @map("updated_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdByUser User?         @relation("PriceCardCreatedBy", fields: [createdBy], references: [id])
  stok          Stok          @relation(fields: [stokId], references: [id], onDelete: Cascade)
  updatedByUser User?         @relation("PriceCardUpdatedBy", fields: [updatedBy], references: [id])

  @@index([stokId, type, createdAt])
  @@map("price_cards")
}

model StockCostHistory {
  id          String   @id @default(uuid())
  stokId      String   @map("stok_id")
  cost        Decimal  @db.Decimal(12, 4)
  method      String   @default("WEIGHTED_AVERAGE")
  computedAt  DateTime @default(now()) @map("computed_at")
  marka       String?
  anaKategori String?
  altKategori String?
  note        String?
  stok        Stok     @relation(fields: [stokId], references: [id], onDelete: Cascade)

  @@index([stokId, computedAt])
  @@map("stock_cost_history")
}

model EsdegerGrup {
  id        String   @id @default(uuid())
  grupAdi   String?
  aciklama  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  urunler   Stok[]

  @@map("esdeger_gruplar")
}

model StokEsdeger {
  id        String   @id @default(uuid())
  stok1Id   String
  stok2Id   String
  createdAt DateTime @default(now())
  stok1     Stok     @relation("Stok1", fields: [stok1Id], references: [id], onDelete: Cascade)
  stok2     Stok     @relation("Stok2", fields: [stok2Id], references: [id], onDelete: Cascade)

  @@unique([stok1Id, stok2Id])
  @@map("stok_esdegers")
}

model StokHareket {
  id          String      @id @default(uuid())
  stokId      String
  hareketTipi HareketTipi
  miktar      Int
  birimFiyat  Decimal     @db.Decimal(10, 2)
  aciklama    String?
  createdAt   DateTime    @default(now())
  warehouseId String?
  stok        Stok        @relation(fields: [stokId], references: [id], onDelete: Cascade)
  warehouse   Warehouse?  @relation(fields: [warehouseId], references: [id])

  @@map("stok_hareketleri")
}

model Cari {
  id                        String                   @id @default(uuid())
  cariKodu                  String
  tenantId                  String?
  unvan                     String
  tip                       CariTip
  sirketTipi                SirketTipi?              @default(KURUMSAL)
  vergiNo                   String?
  vergiDairesi              String?
  tcKimlikNo                String?
  isimSoyisim               String?
  telefon                   String?
  email                     String?
  ulke                      String?                  @default("Türkiye")
  il                        String?
  ilce                      String?
  adres                     String?
  yetkili                   String?
  bakiye                    Decimal                  @default(0) @db.Decimal(12, 2)
  vadeSuresi                Int?
  aktif                     Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  bankaHavaleler            BankaHavale[]
  bankaHesapHareketler      BankaHesapHareket[]
  bordrolar                 Bordro[]
  basitSiparisler           BasitSiparis[]           @relation("BasitSiparisCari")
  cariHareketler            CariHareket[]
  tenant                    Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cekSenetler               CekSenet[]
  faturalar                 Fatura[]
  firmaKrediKartiHareketler FirmaKrediKartiHareket[]
  kasaHareketler            KasaHareket[]
  purchaseOrders            PurchaseOrder[]          @relation("PurchaseOrderSupplier")
  satınAlmaIrsaliyeleri    SatınAlmaIrsaliyesi[]   @relation("SatınAlmaIrsaliyesiCari")
  satinAlmaSiparisleri      SatınAlmaSiparisi[]     @relation("SatınAlmaSiparisiCari")
  satisIrsaliyeleri         SatisIrsaliyesi[]        @relation("SatisIrsaliyesiCari")
  siparisler                Siparis[]
  tahsilatlar               Tahsilat[]
  teklifler                 Teklif[]
  vehicles                  Vehicle[]
  workOrders                WorkOrder[]              @relation("WorkOrderCustomer")
  randevular                Randevu[]                @relation("RandevuCustomer")
  satisElemaniId            String?
  satisElemani              SatisElemani?            @relation(fields: [satisElemaniId], references: [id])

  @@unique([cariKodu, tenantId])
  @@index([tenantId])
  @@index([tenantId, cariKodu])
  @@map("cariler")
}

model CariHareket {
  id        String     @id @default(uuid())
  cariId    String
  tip       BorcAlacak
  tutar     Decimal    @db.Decimal(12, 2)
  bakiye    Decimal    @db.Decimal(12, 2)
  belgeTipi BelgeTipi?
  belgeNo   String?
  tarih     DateTime   @default(now())
  aciklama  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cari      Cari       @relation(fields: [cariId], references: [id], onDelete: Cascade)

  @@index([cariId, tarih])
  @@map("cari_hareketler")
}

model Kasa {
  id                 String            @id @default(uuid())
  kasaKodu           String
  tenantId           String?
  kasaAdi            String
  kasaTipi           KasaTipi
  bakiye             Decimal           @default(0) @db.Decimal(15, 2)
  aktif              Boolean           @default(true)
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  bankaHavaleler     BankaHavale[]
  cekSenetTahsilat   CekSenet[]
  firmaKrediKartlari FirmaKrediKarti[]
  hareketler         KasaHareket[]
  createdByUser      User?             @relation("KasaCreatedBy", fields: [createdBy], references: [id])
  tenant             Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser      User?             @relation("KasaUpdatedBy", fields: [updatedBy], references: [id])
  personelOdemeler   PersonelOdeme[]
  tahsilatlar        Tahsilat[]
  avanslar           Avans[]
  maasOdemeDetaylari MaasOdemeDetay[]

  @@unique([kasaKodu, tenantId])
  @@index([tenantId])
  @@index([tenantId, kasaKodu])
  @@index([kasaTipi])
  @@index([aktif])
  @@map("kasalar")
}

// Banka - Ana banka tanımı
model Banka {
  id        String        @id @default(uuid())
  tenantId  String?
  ad        String
  sube      String?
  sehir     String?
  yetkili   String?
  telefon   String?
  logo      String?
  durum     Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  hesaplar  BankaHesabi[]
  tenant    Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("bankalar")
}

// Banka Hesabı - Bankaya ait hesaplar
model BankaHesabi {
  id                 String              @id @default(uuid())
  bankaId            String
  hesapKodu          String              @unique
  hesapAdi           String?
  hesapNo            String?
  iban               String?
  hesapTipi          BankaHesapTipi
  bakiye             Decimal             @default(0) @db.Decimal(15, 2)
  aktif              Boolean             @default(true)
  // POS hesapları için
  komisyonOrani      Decimal?            @db.Decimal(5, 2)
  // Kredi hesapları için
  krediLimiti        Decimal?            @db.Decimal(15, 2)
  kullanilanLimit    Decimal?            @db.Decimal(15, 2)
  // Firma kredi kartları için
  kartLimiti         Decimal?            @db.Decimal(15, 2)
  hesapKesimGunu     Int?
  sonOdemeGunu       Int?
  terminalNo         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  hareketler         BankaHesapHareket[]
  banka              Banka               @relation(fields: [bankaId], references: [id], onDelete: Cascade)
  tahsilatlar        Tahsilat[]
  maasOdemeDetaylari MaasOdemeDetay[]
  krediler           BankaKredi[]

  @@index([bankaId])
  @@index([hesapTipi])
  @@map("banka_hesaplari")
}

// Banka Hesap Hareketleri - Tüm hesap hareketleri
model BankaHesapHareket {
  id             String               @id @default(uuid())
  hesapId        String
  hareketTipi    BankaHareketTipi
  hareketAltTipi BankaHareketAltTipi?
  tutar          Decimal              @db.Decimal(15, 2)
  komisyonOrani  Decimal?             @db.Decimal(5, 2)
  komisyonTutar  Decimal?             @db.Decimal(15, 2)
  netTutar       Decimal?             @db.Decimal(15, 2)
  bakiye         Decimal              @db.Decimal(15, 2)
  aciklama       String?
  referansNo     String?
  cariId         String?

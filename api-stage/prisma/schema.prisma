  kalemler         WarehouseTransferItem[]
  logs             WarehouseTransferLog[]
  createdByUser    User?                   @relation("WarehouseTransferCreatedBy", fields: [createdBy], references: [id])
  deletedByUser    User?                   @relation("WarehouseTransferDeletedBy", fields: [deletedBy], references: [id])
  fromWarehouse    Warehouse               @relation("WarehouseTransferFrom", fields: [fromWarehouseId], references: [id])
  hazirlayanUser   User?                   @relation("WarehouseTransferHazirlayan", fields: [hazirlayanUserId], references: [id])
  onaylayanUser    User?                   @relation("WarehouseTransferOnaylayan", fields: [onaylayanUserId], references: [id])
  tenant           Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teslimAlanUser   User?                   @relation("WarehouseTransferTeslimAlan", fields: [teslimAlanUserId], references: [id])
  toWarehouse      Warehouse               @relation("WarehouseTransferTo", fields: [toWarehouseId], references: [id])
  updatedByUser    User?                   @relation("WarehouseTransferUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([transferNo, tenantId])
  @@index([fromWarehouseId])
  @@index([tarih])
  @@index([tenantId, durum])
  @@index([tenantId])
  @@index([toWarehouseId])
  @@map("warehouse_transfers")
}


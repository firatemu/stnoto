// SERVİS YÖNETİMİ - Bekleyen Araçlar Modülleri
// ============================================

// Teşhis Modeli - Teknisyenlerin oluşturduğu teşhisler
model Diagnosis {
  id                      String            @id @default(uuid())
  tenantId                String
  workOrderId             String
  category                String?           // Elektrik, Motor, Karoseri, Fren Sistemi, vb.
  title                   String            @db.VarChar(200)
  description             String            @db.Text
  difficulty              DiagnosisLevel    @default(ORTA)
  estimatedHours          Decimal?          @db.Decimal(5, 2)
  status                  DiagnosisStatus   @default(DRAFT)
  priority                DiagnosisPriority @default(ORTA)
  requiresCustomerApproval Boolean          @default(false) // Ek iş varsa true
  customerNotes           String?           @db.Text
  internalNotes           String?           @db.Text
  photos                  Json?             // [{url, caption, uploadedAt}]
  audioNotes              Json?             // [{url, duration, uploadedAt}]
  createdBy               String
  approvedBy              String?           // İlgili departman onay veren kişi
  rejectedBy              String?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  completedAt             DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  
  workOrder               WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@index([workOrderId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("diagnoses")
}

enum DiagnosisStatus {
  DRAFT               // Taslak
  AWAITING_APPROVAL   // Müşteri onayı bekliyor (sadece ek iş varsa)
  APPROVED            // Onaylandı
  REJECTED            // Reddedildi
  IN_PROGRESS         // İşlem yapılıyor
  COMPLETED           // Tamamlandı
}

enum DiagnosisLevel {
  BASIT
  ORTA
  KARMASIK
}

enum DiagnosisPriority {
  DUSUK
  ORTA
  YUKSEK
  ACIL
}

// Teknisyen Zaman Takibi - İkinci aşama için
model TechnicianTimeTracking {
  id              String     @id @default(uuid())
  tenantId        String
  workOrderId     String
  diagnosisId     String?
  technicianId    String
  startedAt       DateTime
  endedAt         DateTime?
  duration        Int?       // Dakika cinsinden
  taskType        String?    // DIAGNOSIS, REPAIR, WAITING, BREAK
  notes           String?    @db.Text
  createdAt       DateTime   @default(now())
  
  workOrder       WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  technician      Technician @relation(fields: [technicianId], references: [id])
  
  @@index([tenantId])
  @@index([workOrderId])
  @@index([technicianId])
  @@index([startedAt])
  @@map("technician_time_tracking")
}

// Program İçi Bildirim Modeli
model InAppNotification {
  id          String             @id @default(uuid())
  tenantId    String
  userId      String             // Alıcı
  type        NotificationType
  title       String             @db.VarChar(200)
  message     String             @db.Text
  actionUrl   String?            // Tıklandığında gidilecek sayfa
  resourceId  String?            // İlgili kaynak (workOrderId, diagnosisId, vb.)
  isRead      Boolean            @default(false)
  createdAt   DateTime           @default(now())
  readAt      DateTime?
  
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([tenantId, userId, isRead])
  @@index([createdAt])
  @@map("in_app_notifications")
}

enum NotificationType {
  WORK_ORDER_ASSIGNED
  WORK_ORDER_CLAIMED
  CUSTOMER_APPROVAL_RECEIVED
  CUSTOMER_APPROVAL_REJECTED
  PARTS_APPROVED
  PARTS_ARRIVED
  DIAGNOSIS_COMPLETED
  WORK_ORDER_STATUS_CHANGED
  SUPPLY_REQUEST_CREATED
  SUPPLY_REQUEST_APPROVED
}

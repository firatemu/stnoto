  @@index([tenantId])
  @@map("bankalar")
}

// Banka Hesabı - Bankaya ait hesaplar
model BankaHesabi {
  id                 String              @id @default(uuid())
  bankaId            String
  hesapKodu          String              @unique
  hesapAdi           String?
  hesapNo            String?
  iban               String?
  hesapTipi          BankaHesapTipi
  bakiye             Decimal             @default(0) @db.Decimal(15, 2)
  aktif              Boolean             @default(true)
  // POS hesapları için
  komisyonOrani      Decimal?            @db.Decimal(5, 2)
  // Kredi hesapları için
  krediLimiti        Decimal?            @db.Decimal(15, 2)
  kullanilanLimit    Decimal?            @db.Decimal(15, 2)
  // Firma kredi kartları için
  kartLimiti         Decimal?            @db.Decimal(15, 2)
  hesapKesimGunu     Int?
  sonOdemeGunu       Int?
  terminalNo         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  hareketler         BankaHesapHareket[]
  banka              Banka               @relation(fields: [bankaId], references: [id], onDelete: Cascade)
  tahsilatlar        Tahsilat[]
  maasOdemeDetaylari MaasOdemeDetay[]
  krediler           BankaKredi[]
  bankaHavaleler     BankaHavale[]
  bordrolar          Bordro[]

  @@index([bankaId])
  @@index([hesapTipi])
  @@map("banka_hesaplari")
}

// Banka Hesap Hareketleri - Tüm hesap hareketleri
model BankaHesapHareket {
  id             String               @id @default(uuid())

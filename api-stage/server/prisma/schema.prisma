model BasitSiparis {
  id                  String            @id @default(uuid())
  tenantId            String?
  firmaId             String
  urunId              String
  miktar              Int
  durum               BasitSiparisDurum @default(ONAY_BEKLIYOR)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tedarikEdilenMiktar Int               @default(0)
  firma               Cari              @relation("BasitSiparisCari", fields: [firmaId], references: [id])
  tenant              Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  urun                Stok              @relation("BasitSiparisStok", fields: [urunId], references: [id])

  @@index([tenantId])
  @@index([tenantId, firmaId])
  @@index([tenantId, urunId])
  @@index([firmaId])
  @@index([urunId])
  @@index([durum])
  @@index([createdAt])
  @@map("basit_siparisler")
}

model SatınAlmaSiparisi {
  id                 String                    @id @default(uuid())
  siparisNo          String
  tenantId           String?
  cariId             String
  tarih              DateTime                  @default(now())
  vade               DateTime?
  iskonto            Decimal                   @default(0) @db.Decimal(10, 2)
  toplamTutar        Decimal                   @db.Decimal(12, 2)
  kdvTutar           Decimal                   @db.Decimal(12, 2)
  genelToplam        Decimal                   @db.Decimal(12, 2)
  aciklama           String?
  durum              SatınAlmaSiparisDurum    @default(BEKLEMEDE)
  faturaNo           String?
  createdBy          String?
  updatedBy          String?
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deliveryNoteId     String?                   @unique
  fatura             Fatura?                   @relation("SatınAlmaSiparisiFatura")
  kaynakIrsaliyeleri SatınAlmaIrsaliyesi[]    @relation("IrsaliyeKaynakSatınAlmaSiparis")
  kalemler           SatınAlmaSiparisKalemi[]
  logs               SatınAlmaSiparisLog[]
  cari               Cari                      @relation("SatınAlmaSiparisiCari", fields: [cariId], references: [id])
  createdByUser      User?                     @relation("SatınAlmaSiparisiCreatedBy", fields: [createdBy], references: [id])
  deletedByUser      User?                     @relation("SatınAlmaSiparisiDeletedBy", fields: [deletedBy], references: [id])
  irsaliye           SatınAlmaIrsaliyesi?     @relation("SatınAlmaSiparisIrsaliye", fields: [deliveryNoteId], references: [id])
  tenant             Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser      User?                     @relation("SatınAlmaSiparisiUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([siparisNo, tenantId])
  @@index([tenantId])
  @@index([tenantId, siparisNo])
  @@index([cariId])
  @@index([durum])
  @@index([createdAt])
  @@map("satin_alma_siparisleri")
}

model SatınAlmaSiparisKalemi {
  id                  String             @id @default(uuid())
  satınAlmaSiparisId String
  stokId              String
  miktar              Int
  sevkEdilenMiktar    Int                @default(0)
  birimFiyat          Decimal            @db.Decimal(10, 2)
  kdvOrani            Int
  kdvTutar            Decimal            @db.Decimal(10, 2)
  tutar               Decimal            @db.Decimal(10, 2)
  createdAt           DateTime           @default(now())
  satınAlmaSiparisi  SatınAlmaSiparisi @relation(fields: [satınAlmaSiparisId], references: [id], onDelete: Cascade)
  stok                Stok               @relation("SatınAlmaSiparisKalemiStok", fields: [stokId], references: [id])

  @@index([satınAlmaSiparisId])
  @@index([stokId])
  @@map("satin_alma_siparis_kalemleri")
}

model SatınAlmaSiparisLog {
  id                  String             @id @default(uuid())
  satınAlmaSiparisId String
  userId              String?
  actionType          LogAction
  changes             String?
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime           @default(now())
  satınAlmaSiparisi  SatınAlmaSiparisi @relation(fields: [satınAlmaSiparisId], references: [id], onDelete: Cascade)
  user                User?              @relation("SatınAlmaSiparisLogUser", fields: [userId], references: [id])

  @@index([satınAlmaSiparisId])
  @@index([userId])
  @@map("satin_alma_siparis_logs")
}

model SatınAlmaIrsaliyesi {
  id                      String                       @id @default(uuid())
  irsaliyeNo              String
  irsaliyeTarihi          DateTime                     @default(now())
  tenantId                String?
  cariId                  String
  depoId                  String?
  kaynakTip               IrsaliyeKaynakTip
  kaynakId                String?
  durum                   IrsaliyeDurum                @default(FATURALANMADI)
  toplamTutar             Decimal                      @db.Decimal(12, 2)
  kdvTutar                Decimal                      @db.Decimal(12, 2)
  genelToplam             Decimal                      @db.Decimal(12, 2)
  iskonto                 Decimal                      @default(0) @db.Decimal(10, 2)
  aciklama                String?
  createdBy               String?
  updatedBy               String?
  deletedAt               DateTime?
  deletedBy               String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  faturalar               Fatura?                      @relation("SatınAlmaIrsaliyesiFatura")
  cari                    Cari                         @relation("SatınAlmaIrsaliyesiCari", fields: [cariId], references: [id])
  createdByUser           User?                        @relation("SatınAlmaIrsaliyesiCreatedBy", fields: [createdBy], references: [id])
  deletedByUser           User?                        @relation("SatınAlmaIrsaliyesiDeletedBy", fields: [deletedBy], references: [id])
  depo                    Warehouse?                   @relation("SatınAlmaIrsaliyesiDepo", fields: [depoId], references: [id])
  kaynakSiparis           SatınAlmaSiparisi?          @relation("IrsaliyeKaynakSatınAlmaSiparis", fields: [kaynakId], references: [id])
  tenant                  Tenant?                      @relation("SatınAlmaIrsaliyesiTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser           User?                        @relation("SatınAlmaIrsaliyesiUpdatedBy", fields: [updatedBy], references: [id])
  kalemler                SatınAlmaIrsaliyesiKalemi[]
  logs                    SatınAlmaIrsaliyesiLog[]
  siparisFromDeliveryNote SatınAlmaSiparisi?          @relation("SatınAlmaSiparisIrsaliye")

  @@unique([irsaliyeNo, tenantId])
  @@index([tenantId])
  @@index([tenantId, irsaliyeNo])
  @@index([tenantId, durum])
  @@index([tenantId, irsaliyeTarihi])
  @@index([cariId])
  @@index([durum])
  @@index([kaynakId])
  @@map("satin_alma_irsaliyeleri")
}

model SatınAlmaIrsaliyesiKalemi {
  id         String               @id @default(uuid())
  irsaliyeId String
  stokId     String
  miktar     Int
  birimFiyat Decimal              @db.Decimal(10, 2)
  kdvOrani   Int
  kdvTutar   Decimal              @db.Decimal(10, 2)
  tutar      Decimal              @db.Decimal(10, 2)
  createdAt  DateTime             @default(now())
  irsaliye   SatınAlmaIrsaliyesi @relation(fields: [irsaliyeId], references: [id], onDelete: Cascade)
  stok       Stok                 @relation("SatınAlmaIrsaliyesiKalemiStok", fields: [stokId], references: [id])

  @@index([irsaliyeId])
  @@index([stokId])
  @@map("satin_alma_irsaliyesi_kalemleri")
}

model SatınAlmaIrsaliyesiLog {
  id         String               @id @default(uuid())
  irsaliyeId String
  userId     String?
  actionType LogAction
  changes    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime             @default(now())
  irsaliye   SatınAlmaIrsaliyesi @relation(fields: [irsaliyeId], references: [id], onDelete: Cascade)
  user       User?                @relation("SatınAlmaIrsaliyesiLogUser", fields: [userId], references: [id])

  @@index([irsaliyeId])
  @@index([userId])
  @@map("satin_alma_irsaliyesi_logs")
}

model Module {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  description  String?
  price        Decimal         @db.Decimal(10, 2)
  currency     String          @default("TRY")
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  licenses     ModuleLicense[]
  userLicenses UserLicense[]

  @@index([slug])
  @@index([isActive])
  @@map("modules")
}

model ModuleLicense {
  id             String       @id @default(cuid())
  subscriptionId String
  moduleId       String
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  module         Module       @relation(fields: [moduleId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([moduleId])
  @@map("module_licenses")
}

model UserLicense {
  id          String      @id @default(cuid())
  userId      String
  licenseType LicenseType
  moduleId    String?
  assignedBy  String?
  assignedAt  DateTime    @default(now())
  revokedAt   DateTime?
  revokedBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  module      Module?     @relation(fields: [moduleId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, licenseType, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@index([licenseType])
  @@map("user_licenses")
}

model Invitation {
  id         String           @id @default(cuid())
  email      String
  tenantId   String
  invitedBy  String
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  acceptedBy String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tenantId])
  @@index([token])
  @@index([status])
  @@map("invitations")
}

model HizliToken {
  id          Int      @id @default(autoincrement())
  token       String
  loginHash   String
  generatedAt DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@index([loginHash])
  @@map("hizli_tokens")
}

model EfaturaInbox {
  id          Int       @id @default(autoincrement())
  ettn        String    @unique
  senderVkn   String
  senderTitle String
  invoiceNo   String?
  invoiceDate DateTime?
  rawXml      String?
  createdAt   DateTime  @default(now())

  @@index([senderVkn])
  @@index([createdAt])
  @@map("efatura_inbox")
}

// ========== Vehicle Service Management Module ==========

enum VehicleServiceStatus {
  BEKLEMEDE              // İş emri beklemede (ilk aşama)
  MUSTERI_ONAYI_BEKLIYOR  // Müşteri onayı bekliyor
  YAPIM_ASAMASINDA       // Araç yapım aşamasında
  PARCA_BEKLIYOR         // Parça bekleniyor
  PARCALAR_TEDARIK_EDILDI // Parçalar tedarik edildi
  ARAC_HAZIR             // Araç hazır
  TAMAMLANDI             // Tamamlandı
}

model CustomerVehicle {
  id              String               @id @default(uuid())
  tenantId        String?
  cariId          String
  plaka           String
  saseno          String?
  yil             Int?
  km              Int?
  aracMarka       String
  aracModel       String
  aracMotorHacmi  String?
  aracYakitTipi   String?
  ruhsatNo        String?
  tescilTarihi    DateTime?
  ruhsatSahibi    String?
  motorGucu       Int?
  sanziman        String?
  renk            String?
  aciklama        String?
  ruhsatPhotoUrl  String?
  servisDurum     VehicleServiceStatus?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  cari            Cari                  @relation(fields: [cariId], references: [id], onDelete: Cascade)
  tenant          Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workOrders      WorkOrder[]

  @@unique([plaka, tenantId])
  @@unique([saseno, tenantId])
  @@index([tenantId])
  @@index([tenantId, cariId])
  @@index([servisDurum])
  @@map("customer_vehicles")
}

model WorkOrder {
  id                     String               @id @default(uuid())
  workOrderNo            String
  tenantId               String?
  status                 WorkOrderStatus      @default(WAITING_DIAGNOSIS)
  partWorkflowStatus     PartWorkflowStatus   @default(NOT_STARTED)
  vehicleWorkflowStatus  VehicleWorkflowStatus @default(WAITING)
  customerVehicleId      String
  cariId                 String
  technicianId           String?
  description            String?
  diagnosisNotes         String?
  supplyResponseNotes    String?
  estimatedCompletionDate DateTime?
  actualCompletionDate   DateTime?
  totalLaborCost         Decimal         @default(0) @db.Decimal(12, 2)
  totalPartsCost         Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount              Decimal         @default(0) @db.Decimal(12, 2)
  grandTotal             Decimal         @default(0) @db.Decimal(12, 2)
  version                Int             @default(1)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  deletedAt              DateTime?
  cari                   Cari            @relation(fields: [cariId], references: [id])
  customerVehicle        CustomerVehicle @relation(fields: [customerVehicleId], references: [id], onDelete: Cascade)
  items                  WorkOrderItem[]
  partRequests           PartRequest[]
  serviceInvoice         ServiceInvoice?
  technician             User?           @relation("WorkOrderTechnician", fields: [technicianId], references: [id])
  tenant                 Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activities             WorkOrderActivity[]

  @@unique([workOrderNo, tenantId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([cariId])
  @@index([technicianId])
  @@map("work_orders")
}

model WorkOrderActivity {
  id          String    @id @default(uuid())
  workOrderId String
  action      String
  userId      String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@index([workOrderId, createdAt])
  @@map("work_order_activities")
}

model WorkOrderItem {
  id          String            @id @default(uuid())
  workOrderId String
  type        WorkOrderItemType
  description String
  stokId      String?
  quantity    Int               @default(1)
  unitPrice   Decimal           @db.Decimal(12, 2)
  taxRate     Int               @default(20)
  taxAmount   Decimal           @default(0) @db.Decimal(12, 2)
  totalPrice  Decimal           @db.Decimal(12, 2)
  version     Int               @default(1)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  stok        Stok?             @relation(fields: [stokId], references: [id])
  workOrder   WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([stokId])
  @@map("work_order_items")
}

model PartRequest {
  id           String            @id @default(uuid())
  tenantId     String?
  workOrderId  String
  requestedBy  String
  description  String
  stokId       String?
  requestedQty Int               @default(1)
  suppliedQty  Int?
  status       PartRequestStatus @default(REQUESTED)
  version      Int               @default(1)
  suppliedBy   String?
  suppliedAt   DateTime?
  usedAt      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  inventoryTransactions InventoryTransaction[]
  requestedByUser User           @relation(fields: [requestedBy], references: [id])
  stok         Stok?            @relation(fields: [stokId], references: [id])
  workOrder    WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  tenant       Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, workOrderId])
  @@index([workOrderId])
  @@index([status])
  @@map("part_requests")
}

model InventoryTransaction {
  id              String                   @id @default(uuid())
  tenantId        String?
  partRequestId   String
  stokId          String
  warehouseId     String?
  quantity        Int
  transactionType InventoryTransactionType @default(DEDUCTION)
  createdAt       DateTime                 @default(now())
  partRequest     PartRequest              @relation(fields: [partRequestId], references: [id], onDelete: Cascade)
  stok            Stok                     @relation(fields: [stokId], references: [id], onDelete: Cascade)
  tenant          Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse       Warehouse?               @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([partRequestId])
  @@index([stokId])
  @@index([tenantId, createdAt])
  @@map("inventory_transactions")
}

model ServiceInvoice {
  id          String    @id @default(uuid())
  tenantId    String?
  invoiceNo   String
  workOrderId String    @unique
  cariId      String
  issueDate   DateTime  @default(now())
  dueDate     DateTime?
  subtotal    Decimal   @db.Decimal(12, 2)
  taxAmount   Decimal   @db.Decimal(12, 2)
  grandTotal  Decimal   @db.Decimal(12, 2)
  dovizCinsi  String    @default("TRY")
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cari        Cari      @relation(fields: [cariId], references: [id])
  createdByUser User?    @relation(fields: [createdBy], references: [id])
  journalEntry  JournalEntry?
  tenant        Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workOrder     WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  tahsilatlar   Tahsilat[]

  @@unique([invoiceNo, tenantId])
  @@index([tenantId])
  @@index([tenantId, issueDate])
  @@index([cariId])
  @@map("service_invoices")
}

model JournalEntry {
  id                String           @id @default(uuid())
  tenantId          String?
  referenceType     String
  referenceId       String
  serviceInvoiceId String?           @unique
  entryDate         DateTime         @default(now())
  description       String?
  createdAt         DateTime         @default(now())
  lines             JournalEntryLine[]
  serviceInvoice    ServiceInvoice?  @relation(fields: [serviceInvoiceId], references: [id], onDelete: SetNull)
  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, referenceType, referenceId])
  @@index([entryDate])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountCode    String
  accountName    String
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  description    String?
  journalEntry   JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@map("journal_entry_lines")
}

// ========== End Vehicle Service Management Module ==========

model FirmaKrediKartiHatirlatici {
  id        String          @id @default(uuid())
  kartId    String
  tip       String
  gun       Int
  aktif     Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  kart      FirmaKrediKarti @relation(fields: [kartId], references: [id], onDelete: Cascade)

  @@unique([kartId, tip])
  @@index([gun, aktif])
  @@index([kartId])
  @@map("firma_kredi_karti_hatirlaticilar")
}

model InvoiceProfit {
  id                String        @id @default(uuid())
  faturaId          String
  faturaKalemiId    String?
  stokId            String
  tenantId          String?
  miktar            Int
  birimFiyat        Decimal       @db.Decimal(10, 2)
  birimMaliyet      Decimal       @db.Decimal(12, 4)
  toplamSatisTutari Decimal       @db.Decimal(12, 2)
  toplamMaliyet     Decimal       @db.Decimal(12, 2)
  kar               Decimal       @db.Decimal(12, 2)
  karOrani          Decimal       @db.Decimal(10, 2)
  hesaplamaTarihi   DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  fatura            Fatura        @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  faturaKalemi      FaturaKalemi? @relation(fields: [faturaKalemiId], references: [id], onDelete: Cascade)
  stok              Stok          @relation(fields: [stokId], references: [id])
  tenants           Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([faturaId])
  @@index([faturaKalemiId])
  @@index([stokId])
  @@index([tenantId, faturaId])
  @@map("invoice_profit")
}

model PostalCode {
  id           String   @id @default(uuid())
  city         String
  district     String
  neighborhood String
  postalCode   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([city, district, neighborhood])
  @@index([city, district])
  @@index([city, district, neighborhood])
  @@index([city])
  @@index([district])
  @@index([neighborhood])
  @@index([postalCode])
  @@map("postal_codes")
}

model SystemParameter {
  id          String   @id @default(uuid())
  tenantId    String?
  key         String
  value       Json
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenants     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([category])
  @@index([tenantId])
  @@map("system_parameters")
}

model WarehouseCriticalStock {
  id          String    @id @default(uuid())
  warehouseId String
  productId   String
  criticalQty Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  stok        Stok      @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([productId])
  @@index([warehouseId])
  @@map("warehouse_critical_stocks")
}

model WarehouseTransferItem {
  id             String            @id @default(uuid())
  transferId     String
  stokId         String
  miktar         Int
  fromLocationId String?
  toLocationId   String?
  createdAt      DateTime          @default(now())
  fromLocation   Location?         @relation("WarehouseTransferItemFrom", fields: [fromLocationId], references: [id])
  stok           Stok              @relation(fields: [stokId], references: [id])
  toLocation     Location?         @relation("WarehouseTransferItemTo", fields: [toLocationId], references: [id])
  transfer       WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([stokId])
  @@index([transferId])
  @@map("warehouse_transfer_items")
}

model WarehouseTransferLog {
  id         String            @id @default(uuid())
  transferId String
  userId     String?
  actionType LogAction
  changes    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime          @default(now())
  transfer   WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  user       User?             @relation(fields: [userId], references: [id])

  @@index([transferId])
  @@index([userId])
  @@map("warehouse_transfer_logs")
}

model WarehouseTransfer {
  id               String                  @id @default(uuid())
  transferNo       String
  tenantId         String?
  tarih            DateTime                @default(now())
  fromWarehouseId  String
  toWarehouseId    String
  durum            TransferStatus          @default(HAZIRLANIYOR)
  driverName       String?
  vehiclePlate     String?
  aciklama         String?
  hazirlayanUserId String?
  onaylayanUserId  String?
  teslimAlanUserId String?
  sevkTarihi       DateTime?
  teslimTarihi     DateTime?
  createdBy        String?
  updatedBy        String?
  deletedAt        DateTime?
  deletedBy        String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  kalemler         WarehouseTransferItem[]
  logs             WarehouseTransferLog[]
  createdByUser    User?                   @relation("WarehouseTransferCreatedBy", fields: [createdBy], references: [id])
  deletedByUser    User?                   @relation("WarehouseTransferDeletedBy", fields: [deletedBy], references: [id])
  fromWarehouse    Warehouse               @relation("WarehouseTransferFrom", fields: [fromWarehouseId], references: [id])
  hazirlayanUser   User?                   @relation("WarehouseTransferHazirlayan", fields: [hazirlayanUserId], references: [id])
  onaylayanUser    User?                   @relation("WarehouseTransferOnaylayan", fields: [onaylayanUserId], references: [id])
  tenant           Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teslimAlanUser   User?                   @relation("WarehouseTransferTeslimAlan", fields: [teslimAlanUserId], references: [id])
  toWarehouse      Warehouse               @relation("WarehouseTransferTo", fields: [toWarehouseId], references: [id])
  updatedByUser    User?                   @relation("WarehouseTransferUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([transferNo, tenantId])
  @@index([fromWarehouseId])
  @@index([tarih])
  @@index([tenantId, durum])
  @@index([tenantId])
  @@index([toWarehouseId])
  @@map("warehouse_transfers")
}


  komisyonTutar  Decimal?             @db.Decimal(15, 2)
  netTutar       Decimal?             @db.Decimal(15, 2)
  bakiye         Decimal              @db.Decimal(15, 2)
  aciklama       String?
  referansNo     String?
  cariId         String?
  tarih          DateTime             @default(now())
  createdAt      DateTime             @default(now())
  cari           Cari?                @relation(fields: [cariId], references: [id])
  hesap          BankaHesabi          @relation(fields: [hesapId], references: [id], onDelete: Cascade)

  @@index([hesapId, tarih])
  @@index([hareketTipi])
  @@map("banka_hesap_hareketler")
}

model BankaKredi {
  id              String           @id @default(uuid())

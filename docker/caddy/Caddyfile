# ==========================================================
# CADDY PROD FINAL (Hardening + Rate-limit + Logs)
# ==========================================================

# Global options (opsiyonel e-posta ekleyebilirsin)
{
  email admin@otomuhasebe.com
  # acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# ---- Ortak güvenlik ve performans ayarları (snippet) ----
(common_security) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data:"
    # İhtiyacına göre CSP'yi sıkılaştır
  }
  encode gzip zstd
  # Access log format (JSON gibi structured log istiyorsan uncomment)
  # log {
  #   output file /var/log/caddy/access.log
  #   format json
  # }
}

#
# NOTE:
# `rate_limit` direktifi Caddy'nin default binary'sinde yoktur (plugin gerekir).
# Bu yüzden rate-limit konfigürasyonu devre dışı bırakıldı.

# ==========================================================
#    PROD ROUTING (Service-name → Docker içi :3000)
# ==========================================================

# ==========================
# STNOTO.COM (Active services)
# ==========================

stnoto.com, www.stnoto.com {
  import common_security
  handle /api/* {
    reverse_proxy stnoto-api:3000
  }
  handle {
    reverse_proxy stnoto-client:3000
  }
}

api.stnoto.com {
  import common_security
  @root path /
  redir @root /api/health temporary
  reverse_proxy stnoto-api:3000
}

